# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Full URL where your app is reachable (required for webhooks). Use https in production.
# Example: https://your-domain.com
WEBHOOK_URL=

# Optional. If set, Telegram sends this in X-Telegram-Bot-Api-Secret-Token; reject requests that don't match.
WEBHOOK_SECRET=

# Database: use PostgreSQL in production, or leave empty for SQLite (local dev)
# Example: postgresql://user:password@localhost:5432/leadbot
DATABASE_URL=

# --- Signal mirroring ---
# Channel where the trader posts signals (Signal Feed). Bot must be admin.
# Example: -1001111111111
SOURCE_CHANNEL_ID=

# Comma-separated list of VIP channel IDs where signals are copied. Bot must be admin in each.
# Example: -10022222222,-10033333333,-10044444444
DESTINATION_CHANNEL_IDS=

# Port for the app (used by gunicorn/uvicorn: -b 0.0.0.0:$PORT)
PORT=8000

# Optional: custom messages for lead tracking
# WELCOME_MESSAGE=Hi! Send your message to join the VIP.
# MESSAGE_REPLY=Thanks, your request was sent.

# --- Telegram MTProto (operator account) ---
# Get these from my.telegram.org — log in with the operator's phone number
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
